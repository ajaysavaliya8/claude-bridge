*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/
.venv/
.venv_clean/
venv/
.tox/
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
*.log
