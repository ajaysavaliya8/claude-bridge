# claude-bridge configuration. Copy to .env and fill in. Each process reads the
# variables it needs; not every variable is meaningful to every process.
# (Comments below mark which component uses each.)

# ============================================================================
# SHARED — broker, MCP server, and responder
# ============================================================================

# Where the broker is reachable. On the broker's own host this is localhost; on
# a remote peer it is the LOCAL end of the SSH tunnel (see scripts/tunnel.sh).
# Security model: the broker binds to 127.0.0.1 only and has no app-level auth —
# the localhost bind + SSH tunnel is the trust boundary. Never expose the port.
BROKER_URL=http://127.0.0.1:8765

# ============================================================================
# BROKER ONLY (broker.py)
# ============================================================================

# Bind address + port. Keep the host on 127.0.0.1 — never 0.0.0.0. Remote peers
# reach the broker through an SSH tunnel, not by binding publicly.
BROKER_HOST=127.0.0.1
BROKER_PORT=8765

# Storage. SQLite file (durable log + shared data + attachment metadata) and the
# on-disk attachment blob store. Defaults sit next to the code if unset.
# WARNING: do NOT place these inside a cloud-sync folder (OneDrive/Dropbox/iCloud).
# SQLite WAL (-wal/-shm) sidecars get corrupted by sync. On Windows prefer e.g.
# %LOCALAPPDATA%\claude-bridge; on Linux ~/.local/state/claude-bridge.
BRIDGE_DB_PATH=./claude_bridge.db
BRIDGE_ATTACHMENTS_DIR=./attachments

# Reject POST bodies larger than this many bytes (pre-parse, via Content-Length).
# Default comfortably fits a 5 MB image base64-encoded (~6.7 MB) plus overhead.
MAX_REQUEST_BYTES=12000000

# Cap on opaque peer/sender/target/key string lengths (anti-abuse).
MAX_NAME_LENGTH=128

# Retention housekeeping: purge answered messages/answers and attachment blobs
# older than this many days (0 = keep everything forever). Sweep interval too.
BRIDGE_RETENTION_DAYS=0
BRIDGE_RETENTION_SWEEP_SECONDS=3600

# ============================================================================
# PER-PEER — MCP server (bridge_mcp.py) and responder (responder.py)
# ============================================================================

# This peer's opaque name. Arbitrary string (web, api, mobile, infra, ...).
# Nothing in the code branches on it.
PEER_SELF=web

# Default peer to talk to when a tool is called without an explicit target.
# Handy in the two-peer case; with 3+ peers, pass target= explicitly instead.
DEFAULT_TARGET=api

# ============================================================================
# RESPONDER ONLY (responder.py)
# ============================================================================

# The project this peer answers about. The responder runs `claude` inside here;
# it can be ANY stack (React, FastAPI, Android, Go, ...). Treated as opaque.
PROJECT_DIR=/absolute/path/to/this/peer/project

# Read-only tool allowlist for headless claude. Keep it read-only so an incoming
# question can never edit files or run shell. Widening this is an explicit,
# documented opt-in and is NOT recommended.
ALLOWED_TOOLS=Read,Grep,Glob

# Caps the agentic loop (and therefore cost) per answer.
MAX_TURNS=15

# Wall-clock cap on a single headless `claude` run. A hung CLI is killed after
# this many seconds and turned into an error answer, so one stuck question can
# never freeze the whole peer. Keep below the asker's ASK_TIMEOUT_SECONDS.
CLAUDE_TIMEOUT_SECONDS=240

# Path to the Claude Code CLI. On Windows this may be claude.cmd; if `claude` is
# on PATH the default resolves it automatically.
CLAUDE_BIN=claude

# Anthropic API key — used for the image/vision path (and available to headless
# claude). Required to answer image-bearing questions.
ANTHROPIC_API_KEY=sk-ant-...

# Vision-capable model for image questions, and the model used for the optional
# text retrieval step that grounds image answers.
VISION_MODEL=claude-sonnet-4-6
RETRIEVAL_MODEL=claude-sonnet-4-6

# Where per-peer headless session ids are cached (for --resume context).
BRIDGE_SESSION_DIR=./.sessions

# Whether a fire-and-forget note (tell_peer) is folded into this peer's resumed
# session as context. true/false.
INJECT_NOTES=true

# ============================================================================
# TIMEOUTS / LONG-POLL WINDOWS (seconds) — usually leave as-is
# ============================================================================

# How long the broker holds a /poll open before returning 204 (responder re-polls).
POLL_WAIT_SECONDS=25
# How long the broker holds one /ask or /reply attempt before returning "pending".
ASK_WAIT_SECONDS=25
# Overall deadline for ask_peer in the MCP server (it re-polls /reply until this).
# NOTE: set the MCP server's per-call `timeout` in .mcp.json ABOVE this value
# (e.g. 600000 ms) or Claude Code may cut the tool call short.
ASK_TIMEOUT_SECONDS=300
# Generic client request timeout for non-long-poll calls.
HTTP_TIMEOUT_SECONDS=30
# Backoff after a responder poll error before retrying.
RESPONDER_POLL_LOOP_PAUSE=3

# ============================================================================
# SIZE LIMITS — usually leave as-is
# ============================================================================
MAX_QUESTION_BYTES=100000
MAX_SHARED_VALUE_BYTES=5000000
